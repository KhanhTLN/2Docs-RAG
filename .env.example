# ─────────────────────────────────────────────
# .env.example  —  Template cấu hình
# Sao chép thành .env rồi điền giá trị thật:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── UI ────────────────────────────────────────
DEMO_MODE=true
BACKEND_URL=http://localhost:8000
API_TIMEOUT=180
API_INGEST_TIMEOUT=300

# ── LLM (Ollama) ──────────────────────────────
# Đảm bảo Ollama đang chạy: ollama serve
# Pull model trước: ollama pull qwen2.5:7b
LLM_BASE_URL=http://localhost:11434
LLM_MODEL_NAME=qwen2.5:14b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# ── Embedding ─────────────────────────────────
# Model sẽ tự download lần đầu chạy (~600MB)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_FP16=true
EMBEDDING_BATCH=8
EMBEDDING_MAXLEN=512

# ── ChromaDB ──────────────────────────────────
CHROMA_METRIC=cosine

# ── Chunking ──────────────────────────────────
CHUNK_MAX=800
CHUNK_OVL=100
CHUNK_MIN=30

# ── Comparison ────────────────────────────────
SIM_THRESHOLD=0.85
CITATION_MIN_LEN=20
MAX_CHANGES=50

# ── FastAPI ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
MAX_FILE_MB=20
